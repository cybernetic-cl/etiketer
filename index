// ═══════════════════════════════════════════════════
//  GENERADOR ZPL (15cm × 10cm a 203 DPI = 1218 × 812 dots)
// ═══════════════════════════════════════════════════
function buildZPL(d) {
  const W = 1218, H = 812;

  // Fecha
  const fechaFmt = d.venc
    ? (() => { const [y,m] = d.venc.split('-'); return `${m}/${String(y).slice(2)}`; })()
    : '--/--';

  // Contenido neto — solo el seleccionado o personalizado
  const contLine = d.contenido;

  // Opciones para el formato ¼ ½ 1 Kilo (si aplica)
  const standardOpts = ['¼ Kilo','½ Kilo','1 Kilo'];
  const sel = standardOpts.indexOf(d.contenido);

  let contZPL = '';
  if (sel >= 0) {
    // Dibujar tres opciones con el marcador seleccionado relleno
    const optX = [830, 920, 1010];
    const labels = ['1/4 Kilo','1/2 Kilo','1 Kilo'];
    optX.forEach((x, i) => {
      const filled = i === sel;
      contZPL += `^FO${x},650^GC18,3,B^FS\n`; // círculo
      if (filled) contZPL += `^FO${x+2},652^GC14,14,B^FS\n`; // relleno
      contZPL += `^FO${x-10},672^A0N,14,14^FD${labels[i]}^FS\n`;
    });
  } else {
    contZPL += `^FO820,650^A0N,22,22^FD${d.contenido}^FS\n`;
  }

  return `^XA
^PW${W}
^LL${H}
^CI28

^FO0,0^GB${W},${H},3^FS

; ── Línea vertical izquierda ──
^FO330,0^GB3,${H},3^FS

; ── Línea vertical derecha ──
^FO980,0^GB3,${H},3^FS

; ── COLUMNA IZQUIERDA ──
^FO15,20^A0N,18,18^FDManipulacion y almacenaje:^FS
^FO15,45^A0N,14,14^FDUtilice siempre EPP adecuado.^FS
^FO15,65^A0N,14,14^FDAlmacene en areas frescas, secas^FS
^FO15,82^A0N,14,14^FDy ventiladas. Evite calor y sol.^FS

^FO15,120^A0N,18,18^FDPrimeros auxilios:^FS
^FO15,145^A0N,13,13^FDEn caso de intoxicacion llame al^FS
^FO15,162^A0N,13,13^FDCITUC: 02 2635 3800^FS
^FO15,179^A0N,13,13^FDatencion 24hrs todos los dias.^FS

; ── COLUMNA CENTRAL ──
; Logo box
^FO420,30^GB160,50,50^FS
^FO430,38^FR^A0N,36,36^FD${d.logo}^FS

; Titulo
^FO340,100^A0N,62,58^FD${d.titulo}^FS

; Subtitulo
^FO400,175^A0N,24,24^FD${d.subtitulo}^FS

; Divider
^FO650,220^GB3,100,3^FS

; Cont neto label
^FO550,335^A0N,20,20^FDcont. neto.^FS

; Opciones de contenido
${contZPL}

; ── COLUMNA DERECHA ──
^FO995,30^A0N,16,16^FDDosis recomendada:^FS
^FO995,50^A0N,14,14^FD${d.dosis}^FS
^FO995,75^A0N,16,16^FDPais de origen: ${d.pais}^FS
^FO995,100^A0N,16,16^FDFecha vencimiento: ${fechaFmt}^FS

; Codigo de barras EAN-13
^FO990,600^BY2,3,70
^BEN,70,Y,N
^FD${d.ean13}^FS

; Distribuidor
^FO990,790^A0N,13,13^FDDistribuido por Cybernetic SpA^FS

^XZ`;
}

// ═══════════════════════════════════════════════════
//  COPIAR ZPL
// ═══════════════════════════════════════════════════
function copiarZPL() {
  const txt = document.getElementById('zpl-output').textContent;
  navigator.clipboard.writeText(txt).then(() => toast('ZPL copiado ✓', 'ok'));
}

// ═══════════════════════════════════════════════════
//  GUARDAR EN FIREBASE
// ═══════════════════════════════════════════════════
async function guardarEtiqueta() {
  if (!window._db) { toast('Firebase no conectado', 'err'); return; }
  const d = getDatos();
  try {
    await window._addDoc(
      window._collection(window._db, 'etiquetas'),
      {
        ...d,
        zpl:        buildZPL(d),
        created_at: window._serverTs(),
      }
    );
    toast('Etiqueta guardada ✓', 'ok');
    if (document.getElementById('app-buscar').classList.contains('active')) {
      cargarEtiquetas();
    }
  } catch(e) {
    console.error(e);
    toast('Error al guardar: ' + e.message, 'err');
  }
}

// ═══════════════════════════════════════════════════
//  CARGAR Y FILTRAR ETIQUETAS
// ═══════════════════════════════════════════════════
let allEtiquetas = [];

async function cargarEtiquetas() {
  if (!window._db) {
    document.getElementById('etiquetas-container').innerHTML =
      '<div class="empty"><div class="empty-icon">🔌</div><p>Firebase no configurado. Edita firebase-config.js</p></div>';
    return;
  }
  document.getElementById('etiquetas-container').innerHTML =
    '<div class="loader"><div class="spinner"></div></div>';
  try {
    const q   = window._query(window._collection(window._db,'etiquetas'), window._orderBy('created_at','desc'));
    const snap = await window._getDocs(q);
    allEtiquetas = snap.docs.map(doc => ({ id: doc.id, ...doc.data() }));
    renderLista(allEtiquetas);
  } catch(e) {
    document.getElementById('etiquetas-container').innerHTML =
      `<div class="empty"><div class="empty-icon">⚠️</div><p>${e.message}</p></div>`;
  }
}

function filtrarEtiquetas() {
  const q = document.getElementById('search-input').value.toLowerCase();
  const f = allEtiquetas.filter(e =>
    (e.titulo   || '').toLowerCase().includes(q) ||
    (e.subtitulo|| '').toLowerCase().includes(q) ||
    (e.ean13    || '').includes(q)
  );
  renderLista(f);
}

function renderLista(lista) {
  const c = document.getElementById('etiquetas-container');
  if (!lista.length) {
    c.innerHTML = '<div class="empty"><div class="empty-icon">📭</div><p>No hay etiquetas guardadas.</p></div>';
    return;
  }
  c.innerHTML = `<div class="etiquetas-grid">${lista.map(renderCard).join('')}</div>`;
  // Render barcodes en cards
  lista.forEach(e => {
    try {
      JsBarcode(`#bc-${e.id}`, e.ean13, { format:'EAN13', width:1, height:35, displayValue:true, fontSize:7, margin:2 });
    } catch(_) {}
  });
}

function renderCard(e) {
  const fechaFmt = e.venc
    ? (() => { const [y,m] = e.venc.split('-'); return `${m}/${String(y).slice(2)}`; })()
    : '';

  return `
  <div class="etiqueta-card">
    <div class="etiqueta-card-preview">
      <div class="label-preview" style="transform:scale(0.42);transform-origin:top center;margin-bottom:-210px;">
        ${buildLabelHTML(e, '-c'+e.id)}
      </div>
    </div>
    <div class="etiqueta-card-info">
      <div class="etiqueta-card-titulo">${e.titulo || '—'}</div>
      <div class="etiqueta-card-sub">${e.subtitulo || ''} · ${e.contenido || ''}</div>
      <div class="etiqueta-card-meta">
        <span class="meta-chip">${e.ean13 || ''}</span>
        ${fechaFmt ? `<span class="meta-chip">Venc: ${fechaFmt}</span>` : ''}
        <span class="meta-chip">${e.logo || ''}</span>
      </div>
      <div class="etiqueta-card-actions">
        <button class="btn btn-primary btn-sm" onclick="abrirModal('${e.id}')">👁 Ver / Imprimir</button>
        <button class="btn btn-ghost btn-sm" onclick="copiarZPLCard('${e.id}')">📋 ZPL</button>
      </div>
    </div>
  </div>`;
}

// ═══════════════════════════════════════════════════
//  MODAL DETALLE
// ═══════════════════════════════════════════════════
function abrirModal(id) {
  const e = allEtiquetas.find(x => x.id === id);
  if (!e) return;
  document.getElementById('modal-titulo').textContent = e.titulo || 'Etiqueta';
  const body = document.getElementById('modal-body');

  const fechaFmt = e.venc
    ? (() => { const [y,m] = e.venc.split('-'); return `${m}/${String(y).slice(2)}`; })()
    : '--/--';

  body.innerHTML = `
    <div style="background:#e8e8e8;border-radius:8px;padding:20px;display:flex;justify-content:center;margin-bottom:20px;">
      <div class="label-preview" id="modal-label-${id}">
        ${buildLabelHTML(e, '-m'+id)}
      </div>
    </div>
    <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
      <button class="btn btn-primary" onclick="imprimirEtiqueta('${id}')">🖨️ Imprimir Etiqueta</button>
      <button class="btn btn-ghost" onclick="copiarZPLCard('${id}')">📋 Copiar ZPL</button>
    </div>
    <div class="zpl-box">
      <div class="zpl-header"><span class="zpl-label">ZPL</span></div>
      <pre style="font-family:var(--font-mono);font-size:10px;color:#a0d0ff;white-space:pre-wrap;max-height:180px;overflow-y:auto;">${buildZPL(e)}</pre>
    </div>
  `;
  document.getElementById('modal-overlay').classList.add('open');

  // render barcode en modal
  setTimeout(() => {
    try {
      JsBarcode(`#barcode-m${id}`, e.ean13, { format:'EAN13', width:1.2, height:45, displayValue:true, fontSize:8, margin:2 });
    } catch(_) {}
  }, 50);
}

function cerrarModal() {
  document.getElementById('modal-overlay').classList.remove('open');
}

function imprimirEtiqueta(id) {
  const e = allEtiquetas.find(x => x.id === id);
  if (!e) return;
  const pa = document.getElementById('print-area');
  pa.style.display = 'flex';
  pa.innerHTML = `<div class="label-preview" id="print-lbl">${buildLabelHTML(e, '-p'+id)}</div>`;
  setTimeout(() => {
    try { JsBarcode(`#barcode-p${id}`, e.ean13, { format:'EAN13', width:1.5, height:55, displayValue:true, fontSize:9, margin:2 }); } catch(_) {}
    setTimeout(() => { window.print(); pa.style.display='none'; }, 200);
  }, 100);
}

function copiarZPLCard(id) {
  const e = allEtiquetas.find(x => x.id === id);
  if (!e) return;
  navigator.clipboard.writeText(buildZPL(e)).then(() => toast('ZPL copiado ✓','ok'));
}

// ═══════════════════════════════════════════════════
//  TABS
// ═══════════════════════════════════════════════════
function showTab(tab) {
  document.querySelectorAll('.app').forEach(a => a.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('app-' + tab).classList.add('active');
  event.target.classList.add('active');
  if (tab === 'buscar') cargarEtiquetas();
}

// ═══════════════════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════════════════
function toast(msg, type='ok') {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'show ' + type;
  setTimeout(() => { el.className = ''; }, 3000);
}

