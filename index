function updatePreview() {
  const d = getDatos();
  const el = document.getElementById('label-preview-main');
  el.innerHTML = buildLabelHTML(d, '-main');
  renderBarcode(d.ean13, 'barcode-main');
  document.getElementById('ean-display').textContent = d.ean13;
  document.getElementById('zpl-output').textContent = buildZPL(d);
