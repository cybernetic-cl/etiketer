function getDatos() {
  const custom = document.getElementById('f-cont-custom').value.trim();
  return {
    titulo:    document.getElementById('f-titulo').value    || 'PRODUCTO',
    subtitulo: document.getElementById('f-subtitulo').value || '',
    contenido: custom || contenidoSeleccionado,
    venc:      document.getElementById('f-venc').value      || '',
    pais:      document.getElementById('f-pais').value      || 'Chile',
    dosis:     document.getElementById('f-dosis').value     || '',
    ean13:     getEAN(),
    logo:      document.getElementById('f-logo').value      || 'AIO',
  };
}

