<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Etiketer — Cybernetic SpA</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">

<!-- JsBarcode para preview EAN-13 -->
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>

<style>
:root {
  --bg:       #0f0f13;
  --surface:  #18181f;
  --surface2: #222230;
  --border:   #2e2e3e;
  --accent:   #6c63ff;
  --accent2:  #ff6584;
  --text:     #e8e8f0;
  --muted:    #7070a0;
  --success:  #22d3a0;
  --warning:  #f59e0b;
  --label-bg: #ffffff;
  --radius:   10px;
  --font-display: 'Space Grotesk', sans-serif;
  --font-body:    'Inter', sans-serif;
  --font-mono:    'JetBrains Mono', monospace;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 15px; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  display: grid;
  grid-template-rows: auto 1fr;
}

/* ── Topbar ── */
.topbar {
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0;
  padding: 0 20px;
  height: 56px;
}
.topbar-logo {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 18px;
  color: var(--accent);
  letter-spacing: -.5px;
  margin-right: 32px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.topbar-logo span { color: var(--text); }
.tab-btn {
  background: none;
  border: none;
  color: var(--muted);
  font-family: var(--font-body);
  font-size: 13px;
  font-weight: 500;
  padding: 18px 16px;
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all .15s;
  white-space: nowrap;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.topbar-spacer { flex: 1; }
.firebase-status {
  font-size: 11px;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: 5px;
}
.status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--muted); }
.status-dot.ok { background: var(--success); }
.status-dot.err { background: var(--accent2); }

/* ── Layout ── */
.app { display: none; padding: 24px; gap: 24px; max-width: 1400px; margin: 0 auto; width: 100%; }
.app.active { display: grid; }
#app-crear { grid-template-columns: 420px 1fr; align-items: start; }
#app-buscar { grid-template-columns: 1fr; }

/* ── Panel ── */
.panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
}
.panel-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.panel-title {
  font-family: var(--font-display);
  font-size: 13px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 1px;
}
.panel-body { padding: 20px; }

/* ── Form ── */
.field { margin-bottom: 16px; }
.field label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .6px;
  margin-bottom: 6px;
}
.field input, .field select, .field textarea {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 7px;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 9px 13px;
  outline: none;
  transition: border-color .15s;
}
.field input:focus, .field select:focus, .field textarea:focus {
  border-color: var(--accent);
}
.field select option { background: var(--surface2); }

/* radio buttons de contenido */
.radio-group { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
.radio-opt { position: relative; }
.radio-opt input[type=radio] { position: absolute; opacity: 0; width: 0; }
.radio-opt label {
  display: block;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 6px 14px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  color: var(--muted);
  transition: all .15s;
  text-transform: none;
  letter-spacing: 0;
}
.radio-opt input:checked + label {
  background: var(--accent);
  border-color: var(--accent);
  color: #fff;
}

/* ── Botones ── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  border: none;
  border-radius: 7px;
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 13px;
  cursor: pointer;
  transition: all .15s;
  padding: 10px 18px;
}
.btn-primary { background: var(--accent); color: #fff; }
.btn-primary:hover { background: #5a52e0; }
.btn-success { background: var(--success); color: #0a0a0a; }
.btn-success:hover { filter: brightness(1.1); }
.btn-ghost { background: var(--surface2); color: var(--text); border: 1px solid var(--border); }
.btn-ghost:hover { border-color: var(--accent); color: var(--accent); }
.btn-danger { background: #3d1515; color: var(--accent2); border: 1px solid #5a2020; }
.btn-danger:hover { background: #5a1515; }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-block { width: 100%; justify-content: center; }
.btn:disabled { opacity: .4; cursor: not-allowed; }

.btn-row { display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap; }

/* ── Preview etiqueta ── */
.preview-wrap {
  position: sticky;
  top: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.preview-label-outer {
  background: #e8e8e8;
  border-radius: var(--radius);
  padding: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* La etiqueta misma: 15cm × 10cm — mostrar a escala ~540×360 */
.label-preview {
  width: 540px;
  height: 360px;
  background: #fff;
  border: 1px solid #ccc;
  font-family: 'Arial', sans-serif;
  position: relative;
  display: grid;
  grid-template-columns: 140px 1fr 130px;
  overflow: hidden;
  box-shadow: 0 4px 24px rgba(0,0,0,.3);
}

/* Columna izquierda — texto vertical */
.lbl-left {
  border-right: 1.5px solid #222;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 10px 8px;
}
.lbl-left-block { }
.lbl-left-title {
  font-size: 8px;
  font-weight: 700;
  color: #111;
  display: block;
  margin-bottom: 4px;
  text-transform: uppercase;
}
.lbl-left-text {
  font-size: 7px;
  color: #333;
  line-height: 1.5;
}

/* Columna central */
.lbl-center {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14px 12px;
  border-right: 1.5px solid #222;
}
.lbl-logo-box {
  background: #111;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  font-family: 'Arial Black', Arial, sans-serif;
  padding: 5px 14px;
  letter-spacing: 1px;
  margin-bottom: 10px;
}
.lbl-titulo {
  font-size: 22px;
  font-weight: 900;
  color: #111;
  text-align: center;
  text-transform: uppercase;
  letter-spacing: -.5px;
  line-height: 1.1;
  margin-bottom: 4px;
}
.lbl-subtitulo {
  font-style: italic;
  font-size: 11px;
  color: #555;
  margin-bottom: 16px;
}
.lbl-divider {
  width: 1px;
  height: 48px;
  background: #222;
  margin-bottom: 12px;
}
.lbl-cont-label {
  font-size: 9px;
  color: #555;
  font-weight: 600;
  letter-spacing: .5px;
  margin-bottom: 8px;
}
.lbl-cont-options {
  display: flex;
  gap: 14px;
  align-items: center;
}
.lbl-cont-item {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #333;
  font-weight: 600;
}
.lbl-circle {
  width: 14px; height: 14px;
  border-radius: 50%;
  border: 1.5px solid #333;
}
.lbl-circle.filled { background: #111; border-color: #111; }

/* Columna derecha */
.lbl-right {
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: flex-end;
  padding: 8px 8px 8px 6px;
}
.lbl-right-info {
  font-size: 7.5px;
  color: #333;
  text-align: right;
  line-height: 1.8;
  margin-bottom: 10px;
  width: 100%;
}
.lbl-right-info strong { font-weight: 700; color: #111; }
.lbl-barcode-wrap {
  width: 100%;
  display: flex;
  justify-content: flex-end;
}
.lbl-barcode-wrap svg, .lbl-barcode-wrap canvas {
  max-width: 118px;
  height: auto;
}

/* Texto lateral distribuidor (rotado) */
.lbl-distribuidor {
  position: absolute;
  right: -30px;
  bottom: 60px;
  transform: rotate(90deg);
  transform-origin: right center;
  font-size: 6.5px;
  color: #aaa;
  white-space: nowrap;
}

/* ── ZPL output ── */
.zpl-box {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
}
.zpl-box pre {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: #a0d0ff;
  white-space: pre-wrap;
  word-break: break-all;
  max-height: 200px;
  overflow-y: auto;
  line-height: 1.6;
}
.zpl-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10px;
}
.zpl-label { font-size: 11px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .5px; }

/* ── Búsqueda ── */
.search-bar {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}
.search-bar input {
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 7px;
  color: var(--text);
  font-family: var(--font-body);
  font-size: 14px;
  padding: 10px 14px;
  outline: none;
}
.search-bar input:focus { border-color: var(--accent); }

/* ── Lista de etiquetas ── */
.etiquetas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 16px;
}
.etiqueta-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: border-color .15s;
}
.etiqueta-card:hover { border-color: var(--accent); }
.etiqueta-card-preview {
  background: #e8e8e8;
  padding: 12px;
  display: flex;
  justify-content: center;
}
.etiqueta-card-preview .label-preview {
  transform: scale(0.45);
  transform-origin: top center;
  margin-bottom: -185px;
}
.etiqueta-card-info {
  padding: 14px 16px;
  border-top: 1px solid var(--border);
}
.etiqueta-card-titulo {
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 2px;
}
.etiqueta-card-sub {
  font-size: 12px;
  color: var(--muted);
  margin-bottom: 10px;
}
.etiqueta-card-meta {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}
.meta-chip {
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 5px;
  font-size: 11px;
  color: var(--muted);
  padding: 2px 8px;
  font-family: var(--font-mono);
}
.etiqueta-card-actions { display: flex; gap: 8px; }

/* ── Modal ── */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,.7);
  z-index: 1000;
  display: none;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(4px);
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 14px;
  width: 90vw;
  max-width: 860px;
  max-height: 90vh;
  overflow-y: auto;
  padding: 28px;
}
.modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
.modal-title { font-family: var(--font-display); font-size: 18px; font-weight: 700; }
.modal-close { background: none; border: none; color: var(--muted); font-size: 22px; cursor: pointer; line-height: 1; }
.modal-close:hover { color: var(--accent2); }

/* ── Toast ── */
#toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 18px;
  font-size: 13px;
  font-weight: 500;
  z-index: 9999;
  opacity: 0;
  transform: translateY(10px);
  transition: all .25s;
  max-width: 300px;
}
#toast.show { opacity: 1; transform: translateY(0); }
#toast.ok { border-color: var(--success); color: var(--success); }
#toast.err { border-color: var(--accent2); color: var(--accent2); }

/* ── Empty state ── */
.empty { text-align: center; padding: 60px 20px; color: var(--muted); }
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty p { font-size: 14px; }

/* ── Loader ── */
.loader { display: flex; justify-content: center; padding: 40px; }
.spinner {
  width: 32px; height: 32px;
  border: 3px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── Print modal ── */
@media print {
  body * { visibility: hidden !important; }
  #print-area, #print-area * { visibility: visible !important; }
  #print-area { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; background: #fff; }
  #print-area .label-preview {
    width: 567px !important; /* 15cm a 96dpi */
    height: 378px !important;
    transform: none !important;
    margin: 0 !important;
    border: 0.5mm solid #ccc !important;
    box-shadow: none !important;
  }
}

.ean-display {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--muted);
  padding: 4px 0;
}
</style>
</head>
<body>

<!-- Topbar -->
<header class="topbar">
  <div class="topbar-logo">🏷️ <span>Etiketer</span></div>
  <button class="tab-btn active" onclick="showTab('crear')">+ Crear Etiqueta</button>
  <button class="tab-btn" onclick="showTab('buscar')">🔍 Buscar / Imprimir</button>
  <div class="topbar-spacer"></div>
  <div class="firebase-status">
    <div class="status-dot" id="fb-dot"></div>
    <span id="fb-label">Conectando...</span>
  </div>
</header>

<!-- ══ TAB: CREAR ══ -->
<div class="app active" id="app-crear">

  <!-- Formulario -->
  <div class="panel">
    <div class="panel-header">
      <span class="panel-title">Datos de la etiqueta</span>
    </div>
    <div class="panel-body">

      <div class="field">
        <label>Título</label>
        <input type="text" id="f-titulo" placeholder="CAFEÍNA ANHIDRA" oninput="updatePreview()">
      </div>

      <div class="field">
        <label>Subtítulo</label>
        <input type="text" id="f-subtitulo" placeholder="Food Grade" oninput="updatePreview()">
      </div>

      <div class="field">
        <label>Contenido Neto</label>
        <div class="radio-group" id="cont-group"></div>
        <input type="text" id="f-cont-custom" placeholder="Cantidad personalizada (ej: 2 Kilos)" style="margin-top:8px;" oninput="updatePreview()">
      </div>

      <div class="field">
        <label>Fecha de Vencimiento</label>
        <input type="month" id="f-venc" oninput="updatePreview()">
      </div>

      <div class="field">
        <label>País de Origen</label>
        <input type="text" id="f-pais" placeholder="China" oninput="updatePreview()" value="China">
      </div>

      <div class="field">
        <label>Dosis Recomendada</label>
        <input type="text" id="f-dosis" placeholder="0,5 gr al día" oninput="updatePreview()" value="0,5 gr al día">
      </div>

      <div class="field">
        <label>Código EAN-13 (autogenerado)</label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="text" id="f-ean" placeholder="Auto" oninput="updatePreview()" maxlength="13" style="flex:1;">
          <button class="btn btn-ghost btn-sm" onclick="generarEAN()">🎲 Generar</button>
        </div>
        <div class="ean-display" id="ean-display"></div>
      </div>

      <div class="field">
        <label>Logo / Marca</label>
        <select id="f-logo" onchange="updatePreview()">
          <option value="AIO">AIO</option>
          <option value="DMP">DMP</option>
          <option value="MASCO">MASCO</option>
        </select>
      </div>

      <div class="btn-row">
        <button class="btn btn-success btn-block" onclick="guardarEtiqueta()">
          💾 Guardar en Firebase
        </button>
      </div>

    </div>
  </div>

  <!-- Preview + ZPL -->
  <div class="preview-wrap">

    <!-- Vista previa -->
    <div class="panel">
      <div class="panel-header">
        <span class="panel-title">Vista Previa — 15 × 10 cm</span>
      </div>
      <div class="panel-body" style="padding:0;">
        <div class="preview-label-outer">
          <div id="label-preview-main" class="label-preview">
            <!-- se genera por JS -->
          </div>
        </div>
      </div>
    </div>

    <!-- ZPL -->
    <div class="zpl-box">
      <div class="zpl-header">
        <span class="zpl-label">ZPL — Zebra 15×10cm · 203 DPI</span>
        <button class="btn btn-ghost btn-sm" onclick="copiarZPL()">📋 Copiar ZPL</button>
      </div>
      <pre id="zpl-output">^XA
^XZ</pre>
    </div>

  </div>
</div>

<!-- ══ TAB: BUSCAR ══ -->
<div class="app" id="app-buscar">
  <div>
    <div class="search-bar">
      <input type="text" id="search-input" placeholder="Buscar por título, EAN o subtítulo..." oninput="filtrarEtiquetas()">
      <button class="btn btn-ghost" onclick="cargarEtiquetas()">🔄 Actualizar</button>
    </div>
    <div id="etiquetas-container">
      <div class="loader"><div class="spinner"></div></div>
    </div>
  </div>
</div>

<!-- Modal detalle -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title" id="modal-titulo">Etiqueta</span>
      <button class="modal-close" onclick="cerrarModal()">✕</button>
    </div>
    <div id="modal-body"></div>
  </div>
</div>

<!-- Área de impresión -->
<div id="print-area" style="display:none;"></div>

<!-- Toast -->
<div id="toast"></div>

<!-- ══ Firebase SDK ══ -->
<script type="module">
import { initializeApp }              from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js';
import { getFirestore, collection, addDoc, getDocs, query, orderBy, serverTimestamp }
  from 'https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js';

// ── Config (editar en firebase-config.js o directamente aquí) ──
const firebaseConfig = {
  apiKey:            "TU_API_KEY",
  authDomain:        "TU_PROJECT.firebaseapp.com",
  projectId:         "TU_PROJECT_ID",
  storageBucket:     "TU_PROJECT.appspot.com",
  messagingSenderId: "TU_SENDER_ID",
  appId:             "TU_APP_ID"
};

let db;
try {
  const app = initializeApp(firebaseConfig);
  db = getFirestore(app);
  document.getElementById('fb-dot').className   = 'status-dot ok';
  document.getElementById('fb-label').textContent = 'Firebase OK';
} catch(e) {
  document.getElementById('fb-dot').className   = 'status-dot err';
  document.getElementById('fb-label').textContent = 'Sin Firebase';
}

// Exponer para uso desde funciones globales
window._db         = db;
window._collection = collection;
window._addDoc     = addDoc;
window._getDocs    = getDocs;
window._query      = query;
window._orderBy    = orderBy;
window._serverTs   = serverTimestamp;
</script>

<script>
// ═══════════════════════════════════════════════════
//  OPCIONES DE CONTENIDO NETO
// ═══════════════════════════════════════════════════
const CONTENIDOS = [
  '¼ Kilo', '½ Kilo', '1 Kilo',
  '100 gr', '250 gr', '500 gr',
  '5 Kilos', '10 Kilos', '25 Kilos'
];

let contenidoSeleccionado = '1 Kilo';

function initContGroup() {
  const g = document.getElementById('cont-group');
  CONTENIDOS.forEach((c, i) => {
    g.innerHTML += `
      <div class="radio-opt">
        <input type="radio" name="contenido" id="co${i}" value="${c}" ${c==='1 Kilo'?'checked':''} onchange="contenidoSeleccionado=this.value;updatePreview()">
        <label for="co${i}">${c}</label>
      </div>`;
  });
}

// ═══════════════════════════════════════════════════
//  EAN-13
// ═══════════════════════════════════════════════════
function calcCheckEAN(digits12) {
  let s = 0;
  digits12.split('').forEach((d, i) => { s += parseInt(d) * (i % 2 === 0 ? 1 : 3); });
  return String((10 - (s % 10)) % 10);
}

function generarEAN() {
  // Prefijo 978 (bookland / genérico)
  const base = '978' + String(Math.floor(Math.random() * 1e8)).padStart(8,'0');
  const ean  = base + calcCheckEAN(base);
  document.getElementById('f-ean').value = ean;
  updatePreview();
  return ean;
}

function getEAN() {
  const v = document.getElementById('f-ean').value.trim();
  if (v.length === 13) return v;
  return generarEAN();
}

// ═══════════════════════════════════════════════════
//  DATOS DE FORMULARIO
