window.generarEAN     = generarEAN;
window.guardarEtiqueta= guardarEtiqueta;
window.cargarEtiquetas= cargarEtiquetas;
window.filtrarEtiquetas=filtrarEtiquetas;
window.abrirModal     = abrirModal;
